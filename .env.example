# Local Docker Postgres (recommended for development):
#   docker run --name pg-exchange -e POSTGRES_PASSWORD=local -p 5432:5432 -d postgres:16
# Then use:
DATABASE_URL="postgresql://postgres:local@localhost:5432/postgres"
# For a hosted DB (Neon, Supabase, etc.) paste their connection string instead.
# Neon needs ?sslmode=require at the end. Docker local does not.

# ---------- Auth ----------

# Comma-separated email allowlist. Only these emails can sign in.
ALLOWED_EMAILS="odhran@howl.ie"

# 32 random bytes, base64. Used to HMAC-sign session cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Where the app is reachable from — used to build magic-link URLs.
# In dev: http://localhost:3000. In production: your Vercel URL.
APP_URL="http://localhost:3000"

# Optional: Resend API key for sending magic-link emails.
# Get one free at resend.com. Leave blank in dev to log the magic link
# to the terminal instead of sending email.
RESEND_API_KEY=""

# Optional: From address for magic-link emails. Defaults to Resend's sandbox
# sender (onboarding@resend.dev). Once you've verified a domain on Resend,
# change to e.g. "The Exchange <login@yourdomain.com>".
AUTH_EMAIL_FROM=""

# ---------- Network ----------

# Set to "true" to engage the network-wide kill switch (also toggleable from UI)
NETWORK_KILL_SWITCH="false"

# iCabbi API base URL. Default is production. Override with the sandbox URL
# (or a self-hosted test environment) without rebuilding.
ICABBI_API_BASE_URL="https://api.icabbi.com/v2"

# Legacy: shared secret for receiving iCabbi webhooks. The real implementation
# uses per-partner webhook secrets stored on partners.credentials.webhookSecret
# (auto-generated when a partner connects). Kept here for any one-off webhook
# routes that need a global secret.
ICABBI_WEBHOOK_SECRET="dev-secret-rotate-me"

# Per-partner credentials are stored in the `partners` table; this is the master key
# used to encrypt them at rest. 32 random bytes, base64.
PARTNER_CREDENTIAL_KEY="generate-with-openssl-rand-base64-32"
