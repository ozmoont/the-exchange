{
  "name": "the-exchange",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx --env-file=.env.local src/scripts/seed.ts",
    "smoke": "tsx --env-file=.env.local src/scripts/smoke-test.ts",
    "send-webhook": "tsx --env-file=.env.local src/scripts/send-webhook.ts",
    "spawn-fleets": "tsx --env-file=.env.local src/scripts/spawn-fleets.ts",
    "fire-jobs": "tsx --env-file=.env.local src/scripts/fire-jobs.ts",
    "backfill-reliability": "tsx --env-file=.env.local src/scripts/backfill-reliability.ts",
    "demo:refresh": "tsx --env-file=.env.local src/scripts/demo-refresh.ts",
    "seed:icabbi-staging": "tsx --env-file=.env.local src/scripts/seed-icabbi-staging.ts",
    "smoke:icabbi-staging": "tsx --env-file=.env.local src/scripts/smoke-icabbi-staging.ts",
    "seed:cmac-test": "tsx --env-file=.env.local src/scripts/seed-cmac-test.ts",
    "smoke:cmac": "tsx --env-file=.env.local src/scripts/smoke-cmac.ts",
    "run-sql": "tsx --env-file=.env.local src/scripts/run-sql.ts"
  },
  "dependencies": {
    "@sentry/nextjs": "^8.55.0",
    "drizzle-orm": "^0.33.0",
    "next": "^15.0.3",
    "postgres": "^3.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/ui": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.24.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
